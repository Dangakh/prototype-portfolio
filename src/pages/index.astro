---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dang Khoa — Portfolio">
  <div class="portfolio">

    <!-- HERO -->
    <section class="hero">
      <img src="/hero.png" alt="Dang Khoa hero" class="hero-img">
      <div class="hero-overlay"></div>
      <div class="hero-grid">
        <div class="logo">Dang<br>Khoa</div>
        <div class="label-num">/ 01</div>
        <div class="label-role">/ Web Designer &amp; Interactive Experiences</div>
        <div class="wordmark-wrap">
          <div class="wordmark">DANGA</div>
        </div>
        <div class="hero-right">
          <p>Craftsmanship that doesn't distract, uniting a trinity of driver, road and vehicled. Inspired by a rich history, engineered for the future.</p>
          <div class="prev-next"><span class="prev">PREV</span> <span class="next">/ NEXT</span></div>
        </div>
      </div>
    </section>

    <!-- INTRODUCTION -->
    <section class="intro-grid">
      <div class="intro-label">/ Introduction</div>
      <p class="intro-text">You've arrived at the portfolio of Dang Khoa Nguyen &ndash; a full stack freelance web designer, creative developer and strategist based in Bergen, Norway.</p>
    </section>

    <!-- WHO I HAVE WORKED WITH -->
    <section class="clients-grid">
      <div class="clients-heading">Who i have<br>worked with</div>

      <div class="client-cell r1c1"><div class="logo-innovasjon"><div class="inn-icon"><span class="inn-dot inn-dot--tl"></span><span class="inn-dot inn-dot--bl"></span><span class="inn-slash"></span></div><div class="inn-name">Innovasjon<br>Norge</div></div></div>
      <div class="client-cell r1c2"><div class="logo-ntnu"><span class="ntnu-sq"></span><div><div class="ntnu-text">NTNU</div><div class="ntnu-sub">Kunnskap for en bedre verder</div></div></div></div>
      <div class="client-cell r1c3"><div class="logo-skypass"><svg width="34" height="30" viewBox="0 0 34 30" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M17 3 L31 11 L17 19 L3 11 Z"></path><path d="M3 11 L3 19 L17 27 L17 19"></path><path d="M31 11 L31 19 L17 27"></path></svg><span class="sky-text">SKYPASS</span></div></div>
      <div class="client-cell r1c4"><div class="logo-innovasjon"><div class="inn-icon"><span class="inn-dot inn-dot--tl"></span><span class="inn-dot inn-dot--bl"></span><span class="inn-slash"></span></div><div class="inn-name">Innovasjon<br>Norge</div></div></div>

      <div class="client-cell r2c1"><div class="logo-innovasjon"><div class="inn-icon"><span class="inn-dot inn-dot--tl"></span><span class="inn-dot inn-dot--bl"></span><span class="inn-slash"></span></div><div class="inn-name">Innovasjon<br>Norge</div></div></div>
      <div class="client-cell r2c2"><div class="logo-ntnu"><span class="ntnu-sq"></span><div><div class="ntnu-text">NTNU</div><div class="ntnu-sub">Kunnskap for en bedre verder</div></div></div></div>
      <div class="client-cell r2c3"><div class="logo-skypass"><svg width="34" height="30" viewBox="0 0 34 30" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M17 3 L31 11 L17 19 L3 11 Z"></path><path d="M3 11 L3 19 L17 27 L17 19"></path><path d="M31 11 L31 19 L17 27"></path></svg><span class="sky-text">SKYPASS</span></div></div>
      <div class="client-cell r2c4"><div class="logo-innovasjon"><div class="inn-icon"><span class="inn-dot inn-dot--tl"></span><span class="inn-dot inn-dot--bl"></span><span class="inn-slash"></span></div><div class="inn-name">Innovasjon<br>Norge</div></div></div>
    </section>

    <!-- EXPERTISE -->
    <section class="expertise-grid">
      <div class="expertise-text">
        <span class="exp-item">Digital Strategy<sup>01</sup></span>
        <span class="exp-div">/</span>
        <span class="exp-item">Branding<sup>02</sup></span>
        <br>
        <span class="exp-item">Web + App Development<sup>03</sup></span>
        <span class="exp-div">/</span>
        <br>
        <span class="exp-item">User Experience<sup>04</sup></span>
        <span class="exp-div">/</span>
        <span class="exp-item">Digital Marketing<sup>05</sup></span>
        <br>
        <span class="exp-item">Media Production<sup>06</sup></span>
        <a href="#" class="exp-link">
          <span>Explore all Expertise</span>
          <span class="exp-arrow">&rarr;</span>
        </a>
      </div>
    </section>

  </div>
</Layout>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  ::selection { background: #F2EED5; color: #0a0a0a; }

  .portfolio {
    background: #0a0a0a;
    width: 100%;
    min-height: 100vh;
    font-family: 'Schibsted Grotesk', sans-serif;
    color: #ededed;
    overflow: hidden;
    padding-bottom: 120px;
  }

  /* HERO */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 38%;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(to top, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.15) 38%, rgba(10,10,10,0) 62%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 20px;
    grid-template-rows: auto 1fr auto auto;
    padding: 34px 64px;
  }

  .logo {
    grid-column: 2 / 5;
    grid-row: 1;
    align-self: start;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 21px;
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: #f6f6f0;
  }

  .label-num {
    grid-column: 1 / 2;
    grid-row: 3;
    align-self: end;
    margin-bottom: 16px;
    font-size: 14.5px;
    letter-spacing: 0.01em;
    color: #e7e3d6;
    white-space: nowrap;
  }

  .label-role {
    grid-column: 2 / 9;
    grid-row: 3;
    align-self: end;
    margin-bottom: 16px;
    font-size: 14.5px;
    letter-spacing: 0.01em;
    color: #bdb9ad;
  }

  .wordmark-wrap {
    grid-column: 2 / 8;
    grid-row: 4;
    align-self: end;
    container-type: inline-size;
  }

  .wordmark {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 28.6cqi;
    line-height: 0.82;
    letter-spacing: -0.01em;
    white-space: nowrap;
    color: #F2EED5;
  }

  .hero-right {
    grid-column: 10 / 13;
    grid-row: 3 / 5;
    align-self: center;
  }

  .hero-right p {
    font-size: 14.5px;
    line-height: 1.42;
    color: #d6d2c7;
  }

  .prev-next {
    margin-top: 42px;
    font-size: 14.5px;
    letter-spacing: 0.02em;
  }

  .prev { color: #f0ece0; }
  .next { color: #8f8b80; }

  /* INTRODUCTION */
  .intro-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 20px;
    padding: 118px 64px 0 64px;
    row-gap: 42px;
  }

  .intro-label {
    grid-column: 2 / 5;
    font-size: 14.5px;
    color: #8f8b80;
    letter-spacing: 0.01em;
  }

  .intro-text {
    grid-column: 2 / 7;
    font-size: 41px;
    line-height: 1.22;
    letter-spacing: -0.015em;
    color: #efece4;
  }

  /* WHO I HAVE WORKED WITH */
  .clients-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 20px;
    row-gap: 84px;
    padding: 248px 64px 0 64px;
    align-items: center;
  }

  .clients-heading {
    grid-column: 1 / 4;
    grid-row: 1 / 3;
    align-self: start;
    font-size: 21px;
    line-height: 1.25;
    color: #efece4;
  }

  .client-cell {
    justify-self: center;
    opacity: 0.62;
    color: #dcdcdc;
  }

  .r1c1 { grid-column: 5 / 7; grid-row: 1; }
  .r1c2 { grid-column: 7 / 9; grid-row: 1; }
  .r1c3 { grid-column: 9 / 11; grid-row: 1; }
  .r1c4 { grid-column: 11 / 13; grid-row: 1; }
  .r2c1 { grid-column: 5 / 7; grid-row: 2; }
  .r2c2 { grid-column: 7 / 9; grid-row: 2; }
  .r2c3 { grid-column: 9 / 11; grid-row: 2; }
  .r2c4 { grid-column: 11 / 13; grid-row: 2; }

  /* Innovasjon Norge logo */
  .logo-innovasjon {
    display: flex;
    align-items: center;
    height: 46px;
    gap: 11px;
  }

  .inn-icon {
    position: relative;
    width: 26px;
    height: 30px;
    flex-shrink: 0;
  }

  .inn-dot {
    position: absolute;
    width: 8px;
    height: 8px;
    background: currentColor;
  }

  .inn-dot--tl { left: 0; top: 0; }
  .inn-dot--bl { left: 0; bottom: 0; }

  .inn-slash {
    position: absolute;
    right: 1px;
    top: 0;
    width: 7px;
    height: 30px;
    background: currentColor;
    transform: skewX(-16deg);
    transform-origin: bottom;
  }

  .inn-name {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-weight: 600;
    font-size: 17px;
    line-height: 1.04;
    letter-spacing: -0.01em;
  }

  /* NTNU logo */
  .logo-ntnu {
    display: flex;
    align-items: center;
    height: 46px;
    gap: 9px;
  }

  .ntnu-sq {
    width: 17px;
    height: 17px;
    background: currentColor;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .ntnu-text {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
    font-size: 24px;
    line-height: 0.9;
    letter-spacing: 0.01em;
  }

  .ntnu-sub {
    font-size: 8.5px;
    letter-spacing: 0.01em;
    color: #9c9c9c;
  }

  /* Skypass logo */
  .logo-skypass {
    display: flex;
    align-items: center;
    height: 46px;
    gap: 12px;
  }

  .sky-text {
    font-weight: 500;
    font-size: 16px;
    letter-spacing: 0.22em;
  }

  /* EXPERTISE */
  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 20px;
    padding: 230px 64px 0 64px;
  }

  .expertise-text {
    grid-column: 2 / 13;
    font-family: 'Schibsted Grotesk', sans-serif;
    font-weight: 400;
    font-size: 69px;
    line-height: 1.16;
    letter-spacing: -0.02em;
    color: #f3f0e8;
  }

  .exp-item {
    white-space: nowrap;
  }

  .exp-item sup {
    font-size: 0.34em;
    font-weight: 400;
    top: -1.4em;
    color: #8f8b80;
    margin-left: 0.05em;
    vertical-align: super;
  }

  .exp-div {
    color: #6f6b61;
    margin: 0 0.16em;
    font-weight: 300;
  }

  .exp-link {
    display: inline-flex;
    align-items: center;
    gap: 38px;
    margin-left: 62px;
    font-size: 18px;
    letter-spacing: 0.01em;
    color: #8f8b80;
    vertical-align: middle;
    transform: translateY(-6px);
    text-decoration: none;
    transition: color 0.2s;
  }

  .exp-link:hover { color: #cfcabd; }

  .exp-arrow {
    font-size: 22px;
    line-height: 1;
  }
</style>
