---
import Layout from '../layouts/Layout.astro';
import { getPageData } from '../lib/sanity';
import type { Client } from '../lib/sanity';

const { settings, clients } = await getPageData();
---

<Layout title="Dang Khoa — Portfolio">
  <div class="portfolio">

    <!-- HERO -->
    <section class="hero">
      <img src="/UpscaledHero.jpeg" alt="Dang Khoa hero" class="hero-img">
      <div class="hero-overlay"></div>
      <div class="hero-grid">
        <div class="logo">Dang<br>Khoa</div>
        <div class="label-num">/ 01</div>
        <div class="label-role">/ {settings.heroRole}</div>
        <div class="wordmark-wrap">
          <div class="wordmark">Dang Khoa Nguyen</div>
        </div>
        <div class="prev-next"><span class="prev">PREV</span> <span class="next">/ NEXT</span></div>
        <div class="hero-right">
          <p>{settings.heroTagline}</p>
        </div>
      </div>
    </section>

    <!-- INTRODUCTION -->
    <section class="intro-grid">
      <div class="intro-label">/ Introduction</div>
      <p class="intro-text">{settings.introBio}</p>
    </section>

    <!-- WHO I HAVE WORKED WITH -->
    <section class="clients-grid">
      <div class="clients-heading">Who i have<br>worked with</div>

      <div class="clients-logo-grid">
        {clients.map((client: Client) => (
          <div class="client-cell">
            {client.logoUrl ? (
              <img src={client.logoUrl} alt={client.name} class="client-logo-img" />
            ) : client.logoKey === 'innovasjon-norge' ? (
              <div class="logo-innovasjon"><div class="inn-icon"><span class="inn-dot inn-dot--tl"></span><span class="inn-dot inn-dot--bl"></span><span class="inn-slash"></span></div><div class="inn-name">Innovasjon<br>Norge</div></div>
            ) : client.logoKey === 'ntnu' ? (
              <div class="logo-ntnu"><span class="ntnu-sq"></span><div><div class="ntnu-text">NTNU</div><div class="ntnu-sub">Kunnskap for en bedre verder</div></div></div>
            ) : client.logoKey === 'skypass' ? (
              <div class="logo-skypass"><svg width="34" height="30" viewBox="0 0 34 30" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M17 3 L31 11 L17 19 L3 11 Z"></path><path d="M3 11 L3 19 L17 27 L17 19"></path><path d="M31 11 L31 19 L17 27"></path></svg><span class="sky-text">SKYPASS</span></div>
            ) : null}
          </div>
        ))}
      </div>
    </section>

    <!-- EXPERTISE -->
    <section class="expertise-grid">
      <div class="expertise-text">
        <span class="exp-item">Digital Strategy<sup>01</sup></span>
        <span class="exp-div">/</span>
        <span class="exp-item">Branding<sup>02</sup></span>
        <br>
        <span class="exp-item">Web + App Development<sup>03</sup></span>
        <span class="exp-div">/</span>
        <br>
        <span class="exp-item">User Experience<sup>04</sup></span>
        <span class="exp-div">/</span>
        <span class="exp-item">Digital Marketing<sup>05</sup></span>
        <br>
        <span class="exp-item">Media Production<sup>06</sup></span>
        <a href="#" class="exp-link">
          <span>Explore all Expertise</span>
          <span class="exp-arrow">&rarr;</span>
        </a>
      </div>
    </section>

  </div>
</Layout>

<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  ::selection { background: #F2EED5; color: #0a0a0a; }

  .portfolio {
    background: #0a0a0a;
    width: 100%;
    min-height: 100vh;
    font-family: 'Schibsted Grotesk', sans-serif;
    color: #ededed;
    overflow: hidden;
    padding-bottom: 7.5rem;       /* 120px */
  }

  /* ── HERO ──────────────────────────────────────────────── */
  .hero {
    position: relative;
    width: 100%;
    height: 100vh;
  }

  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 5%;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(to top, rgba(10,10,10,0.92) 0%, rgba(10,10,10,0.15) 38%, rgba(10,10,10,0) 62%);
  }

  .hero-grid {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 1.25rem;          /* 20px */
    grid-template-rows: auto 1fr auto auto auto;
    padding: 2.125rem 4rem 8rem;  /* 34px 64px 128px */
  }

  .logo {
    grid-column: 2 / 5;
    grid-row: 1;
    align-self: start;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 1.3125rem;         /* 21px */
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: #f6f6f0;
  }

  .label-num {
    grid-column: 1 / 2;
    grid-row: 3;
    align-self: end;
    margin-bottom: 1rem;          /* 16px */
    font-size: 0.906rem;          /* 14.5px */
    letter-spacing: 0.01em;
    color: #e7e3d6;
    white-space: nowrap;
  }

  .label-role {
    grid-column: 2 / 9;
    grid-row: 3;
    align-self: end;
    margin-bottom: 1rem;          /* 16px */
    font-size: 0.906rem;          /* 14.5px */
    letter-spacing: 0.01em;
    color: #bdb9ad;
  }

  .wordmark-wrap {
    grid-column: 2 / 8;
    grid-row: 4;
    align-self: end;
    container-type: inline-size;
  }

  .wordmark {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 8rem;              /* 128px */
    line-height: 0.82;
    letter-spacing: -0.01em;
    color: #F2EED5;
    padding-left: 0;
    margin-left: -1rem;           /* -16px */
  }

  .prev-next {
    grid-column: 2 / 8;
    grid-row: 5;
    align-self: start;
    margin-top: 8rem;             /* 128px */
    font-size: 1.5rem;            /* 24px */
    letter-spacing: 0.02em;
  }

  .hero-right {
    grid-column: 10 / 13;
    grid-row: 1 / 6;
    align-self: end;
  }

  .hero-right p {
    font-size: 1rem;              /* 16px */
    line-height: 1.42;
    color: #d6d2c7;
  }

  .prev { color: #f0ece0; }
  .next { color: #8f8b80; }

  /* ── INTRODUCTION ──────────────────────────────────────── */
  .intro-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 1.25rem;          /* 20px */
    padding: 7.375rem 4rem 0;     /* 118px 64px 0 */
    row-gap: 2.625rem;            /* 42px */
  }

  .intro-label {
    grid-column: 2 / 5;
    font-size: 0.906rem;          /* 14.5px */
    color: #8f8b80;
    letter-spacing: 0.01em;
  }

  .intro-text {
    grid-column: 2 / 8;
    font-size: 2.5625rem;         /* 41px */
    line-height: 1.22;
    letter-spacing: -0.015em;
    color: #efece4;
  }

  /* ── WHO I HAVE WORKED WITH ────────────────────────────── */
  .clients-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 1.25rem;          /* 20px */
    row-gap: 5.25rem;             /* 84px */
    padding: 15.5rem 4rem 0;      /* 248px 64px 0 */
    align-items: center;
  }

  .clients-heading {
    grid-column: 1 / 4;
    grid-row: 1 / 3;
    align-self: start;
    font-size: 1.3125rem;         /* 21px */
    line-height: 1.25;
    color: #efece4;
  }

  .clients-logo-grid {
    grid-column: 5 / 13;
    grid-row: 1 / 3;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 1.25rem;          /* 20px */
    row-gap: 5.25rem;             /* 84px */
    align-content: start;
    align-items: center;
  }

  .client-cell {
    justify-self: center;
    opacity: 0.62;
    color: #dcdcdc;
  }

  .client-logo-img {
    max-height: 2.875rem;         /* 46px */
    max-width: 8.75rem;           /* 140px */
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }

  /* Innovasjon Norge */
  .logo-innovasjon {
    display: flex;
    align-items: center;
    height: 2.875rem;             /* 46px */
    gap: 0.6875rem;               /* 11px */
  }

  .inn-icon {
    position: relative;
    width: 1.625rem;              /* 26px */
    height: 1.875rem;             /* 30px */
    flex-shrink: 0;
  }

  .inn-dot {
    position: absolute;
    width: 0.5rem;                /* 8px */
    height: 0.5rem;
    background: currentColor;
  }

  .inn-dot--tl { left: 0; top: 0; }
  .inn-dot--bl { left: 0; bottom: 0; }

  .inn-slash {
    position: absolute;
    right: 1px;
    top: 0;
    width: 0.4375rem;             /* 7px */
    height: 1.875rem;             /* 30px */
    background: currentColor;
    transform: skewX(-16deg);
    transform-origin: bottom;
  }

  .inn-name {
    font-family: 'Schibsted Grotesk', sans-serif;
    font-weight: 600;
    font-size: 1.0625rem;         /* 17px */
    line-height: 1.04;
    letter-spacing: -0.01em;
  }

  /* NTNU */
  .logo-ntnu {
    display: flex;
    align-items: center;
    height: 2.875rem;             /* 46px */
    gap: 0.5625rem;               /* 9px */
  }

  .ntnu-sq {
    width: 1.0625rem;             /* 17px */
    height: 1.0625rem;
    background: currentColor;
    border-radius: 0.1875rem;     /* 3px */
    flex-shrink: 0;
  }

  .ntnu-text {
    font-family: Georgia, 'Times New Roman', serif;
    font-weight: 700;
    font-size: 1.5rem;            /* 24px */
    line-height: 0.9;
    letter-spacing: 0.01em;
  }

  .ntnu-sub {
    font-size: 0.53125rem;        /* 8.5px */
    letter-spacing: 0.01em;
    color: #9c9c9c;
  }

  /* Skypass */
  .logo-skypass {
    display: flex;
    align-items: center;
    height: 2.875rem;             /* 46px */
    gap: 0.75rem;                 /* 12px */
  }

  .sky-text {
    font-weight: 500;
    font-size: 1rem;              /* 16px */
    letter-spacing: 0.22em;
  }

  /* ── EXPERTISE ─────────────────────────────────────────── */
  .expertise-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 1.25rem;          /* 20px */
    padding: 14.375rem 4rem 0;    /* 230px 64px 0 */
  }

  .expertise-text {
    grid-column: 2 / 13;
    font-family: 'Schibsted Grotesk', sans-serif;
    font-weight: 400;
    font-size: 4.3125rem;         /* 69px */
    line-height: 1.16;
    letter-spacing: -0.02em;
    color: #f3f0e8;
  }

  .exp-item { white-space: nowrap; }

  .exp-item sup {
    font-size: 0.34em;
    font-weight: 400;
    top: -1.4em;
    color: #8f8b80;
    margin-left: 0.05em;
    vertical-align: super;
  }

  .exp-div {
    color: #6f6b61;
    margin: 0 0.16em;
    font-weight: 300;
  }

  .exp-link {
    display: inline-flex;
    align-items: center;
    gap: 2.375rem;                /* 38px */
    margin-left: 3.875rem;        /* 62px */
    font-size: 1.125rem;          /* 18px */
    letter-spacing: 0.01em;
    color: #8f8b80;
    vertical-align: middle;
    transform: translateY(-6px);
    text-decoration: none;
    transition: color 0.2s;
  }

  .exp-link:hover { color: #cfcabd; }

  .exp-arrow {
    font-size: 1.375rem;          /* 22px */
    line-height: 1;
  }

  /* ── TABLET (768–1279px) ───────────────────────────────── */
  @media (max-width: 1279.98px) {
    .hero-grid {
      grid-template-columns: repeat(8, 1fr);
      grid-template-rows: auto 1fr auto auto auto auto;
      padding: 2rem 2rem 6rem;
    }
    .logo        { grid-column: 1 / 4; }
    .label-num   { grid-column: 1 / 2; }
    .label-role  { grid-column: 2 / 8; }
    .wordmark-wrap { grid-column: 1 / 8; }
    .wordmark    { margin-left: 0; }
    .prev-next   { grid-column: 1 / 8; margin-top: 4rem; }
    .hero-right  { grid-column: 1 / 9; grid-row: 6; align-self: start; margin-top: 2rem; }

    .intro-grid  { grid-template-columns: repeat(8, 1fr); padding-inline: 2rem; }
    .intro-label { grid-column: 1 / 4; }
    .intro-text  { grid-column: 1 / 9; font-size: 2rem; }

    .clients-grid {
      grid-template-columns: repeat(8, 1fr);
      padding: 8rem 2rem 0;
      row-gap: 3rem;
    }
    .clients-heading   { grid-column: 1 / 9; grid-row: 1; align-self: start; }
    .clients-logo-grid { grid-column: 1 / 9; grid-row: 2; grid-template-columns: repeat(4, 1fr); row-gap: 3rem; }

    .expertise-grid { grid-template-columns: repeat(8, 1fr); padding: 8rem 2rem 0; }
    .expertise-text { grid-column: 1 / 9; font-size: 3rem; }
    .exp-link       { margin-left: 2rem; }
  }

  /* ── MOBILE (<768px) ───────────────────────────────────── */
  @media (max-width: 767.98px) {
    .portfolio { padding-bottom: 4rem; }

    .hero-grid {
      grid-template-columns: repeat(4, 1fr);
      grid-template-rows: auto 1fr auto auto auto auto;
      padding: 1.5rem 1.25rem 4rem;
    }
    .logo        { grid-column: 1 / 5; }
    .label-num   { display: none; }
    .label-role  { grid-column: 1 / 5; }
    .wordmark-wrap { grid-column: 1 / 5; }
    .wordmark    { margin-left: 0; }
    .prev-next   { grid-column: 1 / 5; margin-top: 2rem; font-size: 1.25rem; }
    .hero-right  { grid-column: 1 / 5; grid-row: 6; align-self: start; margin-top: 2rem; }
    .hero-right p { font-size: 1rem; }

    .intro-grid  { grid-template-columns: repeat(4, 1fr); padding: 4rem 1.25rem 0; row-gap: 1.5rem; }
    .intro-label { grid-column: 1 / 5; }
    .intro-text  { grid-column: 1 / 5; font-size: 1.75rem; }

    .clients-grid {
      grid-template-columns: repeat(4, 1fr);
      padding: 5rem 1.25rem 0;
      row-gap: 2.5rem;
    }
    .clients-heading   { grid-column: 1 / 5; grid-row: 1; }
    .clients-logo-grid { grid-column: 1 / 5; grid-row: 2; grid-template-columns: repeat(2, 1fr); row-gap: 2.5rem; }

    .expertise-grid { grid-template-columns: repeat(4, 1fr); padding: 5rem 1.25rem 0; }
    .expertise-text { grid-column: 1 / 5; font-size: 2rem; }
    .exp-item       { white-space: normal; }
    .exp-link       { display: flex; margin-left: 0; margin-top: 1.5rem; font-size: 1rem; }
  }
</style>
