---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Ship Studio Starter">
  <main class="min-h-screen px-6 py-16 md:px-12 lg:px-24">
    <div class="mx-auto max-w-3xl">
      <!-- Hero Section -->
      <section class="mb-24">
        <p class="mb-4 text-sm font-medium tracking-wide text-muted uppercase">
          Ship Studio
        </p>
        <h1 class="mb-6 font-display text-4xl font-semibold tracking-tight md:text-5xl">
          How professionals build with AI.
        </h1>
        <p class="text-lg text-muted">
          Just describe what you want. Your AI builds it, refines it, and helps you ship.
        </p>
      </section>

      <!-- Getting Started Section -->
      <section class="mb-24">
        <h2 class="mb-8 font-display text-2xl font-semibold">Getting started</h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-foreground/10 font-display text-sm font-medium">
              1
            </div>
            <div>
              <h3 class="font-display font-medium">Start a conversation</h3>
              <p class="text-muted">Describe your project naturally. Share examples, reference other sites, or just explain what you're building.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-foreground/10 font-display text-sm font-medium">
              2
            </div>
            <div>
              <h3 class="font-display font-medium">AI builds it</h3>
              <p class="text-muted">Watch as your AI generates pages, styles, and components in real-time. Everything runs locally in your project.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-foreground/10 font-display text-sm font-medium">
              3
            </div>
            <div>
              <h3 class="font-display font-medium">Refine together</h3>
              <p class="text-muted">Keep iterating until it's right. Ask for changes, try different layouts, add new sections. No pressure.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- Commands Section -->
      <section class="mb-24">
        <h2 class="mb-8 font-display text-2xl font-semibold">Available commands</h2>
        <div class="space-y-4">
          <div class="rounded-lg border border-foreground/10 p-4">
            <code class="font-mono text-accent">/onboarding</code>
            <p class="mt-1 text-sm text-muted">Sets up new projects with personalized planning and structure.</p>
          </div>
          <div class="rounded-lg border border-foreground/10 p-4">
            <code class="font-mono text-accent">/page-remake</code>
            <p class="mt-1 text-sm text-muted">Rebuilds your site based on a shared example or reference.</p>
          </div>
        </div>
      </section>

      <!-- What You Can Build Section -->
      <section class="mb-24">
        <h2 class="mb-8 font-display text-2xl font-semibold">What you can build</h2>
        <div class="mb-6 flex flex-wrap gap-2">
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Landing pages</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Portfolios</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Company sites</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Web apps</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Dashboards</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Event sites</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Personal sites</span>
          <span class="rounded-full bg-foreground/5 px-3 py-1 text-sm">Anything you can imagine</span>
        </div>
        <p class="text-muted">All built with AI, at professional quality.</p>
      </section>

      <!-- CTA Section -->
      <section class="rounded-xl bg-foreground/5 p-8 text-center">
        <p class="font-display text-lg font-medium">
          Just describe what you want to build.
        </p>
        <p class="mt-2 text-muted">Your AI takes it from there.</p>
      </section>
    </div>
  </main>
</Layout>
